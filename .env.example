# 应用环境
APP_ENV=production

# 数据库配置
DB_HOST=mysql
DB_PORT=3306
DB_NAME=ai_article_system
DB_USER=app_user
DB_PASS=changeme_strong_password

# MySQL Root密码（仅docker-compose使用）
DB_ROOT_PASS=changeme_root_password

# AI API 配置
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_API_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

AILION_API_KEY=sk-your-ailion-key-here
AILION_API_URL=https://api.ailion.top
AILION_MODEL=gpt-3.5-turbo

# 初始管理员账号（首次部署后可删除）
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@2025

# Session 配置
SESSION_LIFETIME=7200
SESSION_COOKIE_SAMESITE=Lax

# 话题生成限流
TOPIC_MIN_COUNT=5
TOPIC_MAX_COUNT=10
TOPIC_REQUEST_LIMIT=5
TOPIC_REQUEST_WINDOW=60
