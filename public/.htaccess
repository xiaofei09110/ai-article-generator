# 启用Rewrite引擎
RewriteEngine On
RewriteBase /

# 安全头设置
<IfModule mod_headers.c>
    # 防点击劫持 - 仅允许同源iframe
    Header always set X-Frame-Options "SAMEORIGIN"

    # 防MIME嗅探 - 强制浏览器识别Content-Type
    Header always set X-Content-Type-Options "nosniff"

    # 启用浏览器XSS防护
    Header always set X-XSS-Protection "1; mode=block"

    # 内容安全策略（CSP）- 严格的内容控制
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com; img-src 'self' data: https:; font-src 'self' https://cdnjs.cloudflare.com; connect-src 'self'; base-uri 'self'; form-action 'self';"

    # 推荐者政策 - 保护用户隐私
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # 权限策略 - 限制浏览器功能
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"

    # HSTS (HTTP Strict Transport Security) - 强制HTTPS (生产环境)
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # 禁用跨域请求（仅同源）
    # Header set Access-Control-Allow-Origin "http://localhost:8080"
    # 如需启用CORS，在特定API中单独设置
</IfModule>

# 防直接访问某些文件
<FilesMatch "\.env.*$|\.git.*$|Dockerfile|docker-compose\.yml">
    Order allow,deny
    Deny from all
</FilesMatch>

# 禁止访问日志目录
<DirectoryMatch "^/var/log">
    Order allow,deny
    Deny from all
</DirectoryMatch>

# 禁止列出目录
Options -Indexes

# PHP文件处理
<FilesMatch "\.php$">
    SetHandler application/x-httpd-php
</FilesMatch>

# 静态资源缓存（css, js, images）
<FilesMatch "\.(jpg|jpeg|png|gif|ico|css|js|svg|woff|woff2|ttf|eot)$">
    Header set Cache-Control "max-age=31536000, public"
    ExpiresActive On
    ExpiresDefault "access plus 1 year"
</FilesMatch>

# HTML不缓存（每次都检查）
<FilesMatch "\.(html|htm|php)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "0"
</FilesMatch>

# URL重写规则（用于friendly URLs，可选）
# 将所有不存在的文件和目录请求转到index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
# RewriteRule ^ index.php [QSA,L]
